# App Store Connect / fastlane configuration.
# Copy to fastlane/.env for local metadata work. Do not commit fastlane/.env.

APP_IDENTIFIER=app.tenos.als
FASTLANE_APPLE_ID=
FASTLANE_TEAM_ID=
ASC_APP_ID=

# App Store Connect API key.
ASC_KEY_ID=
ASC_ISSUER_ID=
ASC_KEY_PATH=./fastlane/AuthKey.p8

# Optional comma-separated metadata language filter, for example:
# LANGUAGES=de-DE,en-US
LANGUAGES=

# Optional App Review note uploaded with metadata.
APP_REVIEW_NOTES=TENOS does not require a demo login. Account setup is performed in-app. The app is for personal health documentation and does not provide diagnoses or treatment recommendations.

# Google Play Store configuration.
ANDROID_PACKAGE=app.tenos.als
PLAY_JSON_KEY_PATH=../play-service-account.json
