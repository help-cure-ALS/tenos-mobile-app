EXPO_PUBLIC_SYNC_AUTO_REPAIR=1
EXPO_PUBLIC_SYNC_ALLOW_HARD_RESET=0

# Optional official build metadata. Configure these in local shell, CI, or EAS
# environments for the official app. Forks can leave them empty.
TENOS_EXPO_OWNER=
TENOS_EAS_PROJECT_ID=
TENOS_UPDATES_URL=
TENOS_APPLE_TEAM_ID=
TENOS_IOS_BUNDLE_IDENTIFIER=app.tenos.als
TENOS_ANDROID_PACKAGE=app.tenos.als

# Use deployment URLs for your own environment. Do not point forks at TENOS
# production services unless that is intentional.
EXPO_PUBLIC_VAULT_BASE_URL=https://sync-vault.example.org/
EXPO_PUBLIC_VAULT_APP_ISSUE_TOKEN=change_me_long_random_string

# Optional: verbose vault/sync diagnostics in development
EXPO_PUBLIC_SYNC_DEBUG_LOGS=0

# Verification service
EXPO_PUBLIC_VERIFICATION_URL=https://care.example.org/vapi

# Care server (public studies/clinics data)
EXPO_PUBLIC_CARE_BASE_URL=https://care.example.org/api/
EXPO_PUBLIC_CARE_CLIENT_ID=
EXPO_PUBLIC_CARE_CLIENT_SECRET=

# Supplier proxy
EXPO_PUBLIC_SUPPLIER_PROXY_URL=https://care.example.org/sapi

# Optional: background inbound proposal pull throttle (ms, default 60000)
EXPO_PUBLIC_SUPPLIER_PULL_INTERVAL_MS=60000

# Research server (remote metric/questionnaire definitions) & Research donation proxy
EXPO_PUBLIC_RESEARCH_PROXY_URL=https://research.example.org/donate
EXPO_PUBLIC_RESEARCH_BASE_URL=https://research.example.org/api/
EXPO_PUBLIC_RESEARCH_CLIENT_ID=
EXPO_PUBLIC_RESEARCH_CLIENT_SECRET=
