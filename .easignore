# .easignore REPLACES .gitignore for EAS builds.
# It must include everything from .gitignore plus extra build exclusions.

# ── From .gitignore ──

# dependencies
node_modules/

# Expo
.expo/
dist/
web-build/
expo-env.d.ts

# Native (generated by prebuild — EAS runs its own prebuild)
.kotlin/
*.orig.*
*.jks
*.p8
*.p12
*.key
*.mobileprovision

# Metro
.metro-health-check*

# debug
npm-debug.*
yarn-debug.*
yarn-error.*
.tmp/

# macOS
.DS_Store
*.pem

# local env files
.env
.env*.local
play-service-account.json

# typescript
*.tsbuildinfo

# generated native folders
/ios
/android

# Claude Code
.claude/

# Local planning/tasks
docs/tasks/

# Worktrees
.worktrees/

# Fastlane
fastlane/.env
fastlane/report.xml
fastlane/Preview.html
fastlane/screenshots/**/README.md
vendor/bundle/

# ── Extra EAS exclusions (not needed for builds) ──

# Fastlane screenshots & metadata (only for App Store submission)
fastlane/screenshots/
fastlane/metadata/

# Git history
.git/

# Documentation
docs/
CONTRIBUTING.md
SECURITY.md
LICENSE
README.md

# Tests (not needed for production build)
tests/

# Dev scripts
scripts/
