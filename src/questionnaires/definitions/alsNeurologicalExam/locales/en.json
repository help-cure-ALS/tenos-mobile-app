        "lmnWeakness": {
            "label": "LMN: weakness",
            "info": "Documents clinical muscle weakness as a sign of lower motor neuron involvement."
        },
        "lmnAtrophy": {
            "label": "LMN: atrophy",
            "info": "Documents visible or palpable muscle wasting in the examined region."
        },
        "lmnFasciculations": {
            "label": "LMN: fasciculations",
            "info": "Documents spontaneous muscle twitches as a sign of lower motor neuron irritation or damage."
        },
        "umnHyperreflexia": {
            "label": "UMN: hyperreflexia",
            "info": "Documents increased deep tendon reflexes as a sign of upper motor neuron involvement."
        },
        "umnPathologicalReflexes": {
            "label": "UMN: pathological reflexes",
            "info": "Documents pathological reflex signs such as Babinski or Hoffmann signs."
        },
        "umnSpasticity": {
            "label": "UMN: spasticity",
            "info": "Documents increased muscle tone or spasticity as a sign of upper motor neuron involvement."
        },
        "umnSlowedMovement": {
            "label": "UMN: slowed movement",
            "info": "Documents slowed or poorly coordinated movement not explained by weakness alone."
